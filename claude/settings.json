{
  "env": {
    "ANTHROPIC_AUTH_TOKEN": "",
    "ANTHROPIC_BASE_URL": "https://coding.dashscope.aliyuncs.com/apps/anthropic",
    "ANTHROPIC_MODEL": "glm-5"
  },
  "statusLine": {
    "type": "command",
    "command": "jq -r '\"[\\(.model.display_name)] \\(((.context_window.total_input_tokens // 0) + (.context_window.total_output_tokens // 0)) * 100 / (.context_window.context_window_size // 1) | floor)% context\"'"
  },
  "enabledPlugins": {}
}